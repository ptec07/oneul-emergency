# 오늘응급 Backend
# Copy to .env and fill in real keys. Do not commit .env.
# The backend also accepts PUBLIC_DATA_SERVICE_KEY from /home/ptec07/.hermes/.env for local Hermes runs.
ONEUL_EMERGENCY_PUBLIC_DATA_SERVICE_KEY=YOUR_DATA_GO_KR_SERVICE_KEY
# Set this to your deployed frontend URL, for example https://oneul-emergency.vercel.app
ONEUL_EMERGENCY_FRONTEND_ORIGIN=https://your-frontend.example
# Render supplies PORT automatically. Keep a local default for manual runs.
PORT=8000
